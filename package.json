{
  "name": "aouo-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "aouo monorepo root — workspace meta for @aouo/agent, @aouo/dashboard, docs.",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @aouo/agent --filter @aouo/dashboard dev",
    "dev:agent": "pnpm --filter @aouo/agent dev",
    "dev:dashboard": "pnpm --filter @aouo/dashboard dev",
    "dev:ui": "AOUO_UI_TOKEN=devtoken node packages/agent/dist/bin/aouo.js ui start --no-open",
    "build": "pnpm --filter @aouo/dashboard build && pnpm --filter @aouo/agent build",
    "build:agent": "pnpm --filter @aouo/agent build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "lint:ci": "pnpm -r lint:ci",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write 'packages/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'packages/**/*.{ts,tsx}'",
    "docs:dev": "pnpm --filter @aouo/docs dev",
    "docs:build": "pnpm --filter @aouo/docs build",
    "docs:preview": "pnpm --filter @aouo/docs preview",
    "docs:validate": "pnpm --filter @aouo/docs build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aouoai/aouo.git"
  },
  "author": "aouoai",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
