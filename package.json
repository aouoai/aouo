{
  "name": "aouo-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "aouo monorepo root — workspace meta for @aouo/agent, @aouo/dashboard, docs.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "lint:ci": "pnpm -r lint:ci",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write 'packages/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'packages/**/*.{ts,tsx}'",
    "docs:dev": "cd docs && mint dev",
    "docs:build": "cd docs && mint build",
    "docs:validate": "cd docs && mint validate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aouoai/aouo.git"
  },
  "author": "aouoai",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
