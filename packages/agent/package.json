{
  "name": "@aouo/agent",
  "version": "0.0.1-alpha.2",
  "description": "Vertical agent app platform — install packs, not prompts.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aouo": "dist/bin/aouo.js"
  },
  "files": [
    "README.md",
    "dist",
    "templates"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ bin/ tests/",
    "lint:ci": "eslint src/ bin/ tests/ --max-warnings 115",
    "lint:fix": "eslint src/ bin/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm lint:ci && pnpm typecheck && pnpm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aouoai/aouo.git",
    "directory": "packages/agent"
  },
  "keywords": [
    "agent",
    "ai",
    "vertical-agent",
    "agent-app",
    "pack",
    "react-loop",
    "telegram",
    "llm"
  ],
  "author": "aouoai",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/aouoai/aouo/issues"
  },
  "homepage": "https://aouo.ai",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "@tavily/core": "^0.7.3",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "cron-parser": "^5.5.0",
    "grammy": "^1.42.0",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.1",
    "p-queue": "^9.1.2",
    "pino": "^9.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@aouo/dashboard": "workspace:*",
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
