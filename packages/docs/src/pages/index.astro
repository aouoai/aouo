---
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/600.css';

const links = [
  {
    label: 'Quick Start',
    href: '/getting-started/quickstart/',
    text: 'Install the runtime, initialize ~/.aouo, configure Telegram, and run the gateway.',
  },
  {
    label: 'Architecture',
    href: '/concepts/architecture/',
    text: 'See how providers, adapters, packs, persist, memory, and cron fit together.',
  },
  {
    label: 'Build a Pack',
    href: '/build-a-pack/first-pack/',
    text: 'Create a local vertical agent app with skills, schema, tools, and scoped state.',
  },
];

const stages = [
  ['Adapter', 'Normalize channel events'],
  ['Router', 'Resolve active pack + skill'],
  ['Agent', 'Run with pack-scoped context'],
  ['Persist', 'Write durable domain state'],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="aouo is a local-first vertical agent app platform." />
    <link rel="icon" href="/favicon.svg" />
    <title>aouo - vertical agent app platform</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Primary">
        <a class="brand" href="/" aria-label="aouo home">
          <img src="/favicon.svg" alt="" />
          <span>AOUO</span>
        </a>
        <div class="nav-links">
          <a href="/getting-started/quickstart/">Docs</a>
          <a href="https://github.com/aouoai/aouo">GitHub</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Local-first vertical agent runtime</p>
          <h1>Build agent apps that keep state, schedule work, and run through real channels.</h1>
          <p class="lead">
            aouo turns a vertical agent into a local app contract: a pack owns skills,
            memory, schema, cron jobs, permissions, and a durable persist boundary.
          </p>
          <div class="actions">
            <a class="button primary" href="/getting-started/quickstart/">Quick Start</a>
            <a class="button secondary" href="/getting-started/introduction/">Read the model</a>
          </div>
        </div>

        <div class="diagram-shell" aria-label="aouo runtime flow">
          <svg class="runtime-diagram" viewBox="0 0 760 520" role="img" aria-labelledby="flow-title flow-desc">
            <title id="flow-title">aouo runtime flow</title>
            <desc id="flow-desc">
              Channel adapters normalize messages, the router selects an active pack,
              the agent executes a skill, and persist, memory, and cron close the loop.
            </desc>
            <defs>
              <marker id="arrow" markerWidth="10" markerHeight="10" refX="8" refY="5" orient="auto">
                <path d="M 0 0 L 10 5 L 0 10 z" fill="#1f2937" />
              </marker>
            </defs>

            <rect x="0" y="0" width="760" height="520" rx="8" fill="#ffffff" />

            <g class="lane incoming">
              <rect x="44" y="96" width="134" height="54" rx="8" />
              <text x="111" y="118" text-anchor="middle">Telegram</text>
              <text x="111" y="137" text-anchor="middle" class="small">messages</text>

              <rect x="44" y="222" width="134" height="54" rx="8" />
              <text x="111" y="244" text-anchor="middle">Web UI</text>
              <text x="111" y="263" text-anchor="middle" class="small">config + chat</text>
            </g>

            <g class="core">
              <rect x="260" y="126" width="130" height="74" rx="8" />
              <text x="325" y="154" text-anchor="middle">Adapter</text>
              <text x="325" y="174" text-anchor="middle" class="small">normalize event</text>

              <rect x="452" y="126" width="130" height="74" rx="8" />
              <text x="517" y="154" text-anchor="middle">Router</text>
              <text x="517" y="174" text-anchor="middle" class="small">pack + skill</text>

              <rect x="310" y="278" width="222" height="92" rx="8" />
              <text x="421" y="309" text-anchor="middle">Active Pack</text>
              <text x="421" y="331" text-anchor="middle" class="small">skills · tools · permissions</text>
              <text x="421" y="350" text-anchor="middle" class="small">schema · memory templates</text>
            </g>

            <g class="state">
              <rect x="92" y="410" width="138" height="58" rx="8" />
              <text x="161" y="434" text-anchor="middle">Persist</text>
              <text x="161" y="453" text-anchor="middle" class="small">pack DB</text>

              <rect x="312" y="410" width="138" height="58" rx="8" />
              <text x="381" y="434" text-anchor="middle">Memory</text>
              <text x="381" y="453" text-anchor="middle" class="small">USER/MEMORY</text>

              <rect x="532" y="410" width="138" height="58" rx="8" />
              <text x="601" y="434" text-anchor="middle">Cron</text>
              <text x="601" y="453" text-anchor="middle" class="small">scheduled jobs</text>
            </g>

            <path class="flow-line" d="M178 123 C220 123 220 142 260 150" />
            <path class="flow-line" d="M178 249 C226 249 226 195 260 178" />
            <path class="flow-line direct" d="M390 163 L452 163" />
            <path class="flow-line direct" d="M517 200 C517 238 472 248 440 278" />
            <path class="flow-line direct" d="M356 370 C306 398 246 408 230 430" />
            <path class="flow-line direct" d="M421 370 L381 410" />
            <path class="flow-line direct" d="M490 370 C520 395 556 408 572 430" />

            <circle class="pulse p1" r="4">
              <animateMotion dur="5s" repeatCount="indefinite" path="M178 123 C220 123 220 142 260 150 L390 163 L452 163" />
            </circle>
            <circle class="pulse p2" r="4">
              <animateMotion dur="6s" begin="1.1s" repeatCount="indefinite" path="M517 200 C517 238 472 248 440 278 L421 370 L381 410" />
            </circle>
            <circle class="pulse p3" r="4">
              <animateMotion dur="6.4s" begin="2.2s" repeatCount="indefinite" path="M421 370 C356 390 246 408 230 430" />
            </circle>
          </svg>
        </div>
      </section>

      <section class="start" aria-label="Start points">
        {links.map((item) => (
          <a class="link-card" href={item.href}>
            <strong>{item.label}</strong>
            <span>{item.text}</span>
          </a>
        ))}
      </section>

      <section class="contract">
        <div>
          <p class="eyebrow">Runtime contract</p>
          <h2>Apps are packs. Workflows are skills. State only enters through persist.</h2>
        </div>
        <ol>
          {stages.map(([name, text]) => (
            <li>
              <strong>{name}</strong>
              <span>{text}</span>
            </li>
          ))}
        </ol>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --aouo-mono:
      'JetBrains Mono',
      ui-monospace,
      'SFMono-Regular',
      'SF Mono',
      Consolas,
      'Liberation Mono',
      monospace;
    --ink: #171717;
    --muted: #5f5f66;
    --soft: #f7f7f8;
    --paper: #ffffff;
    --line: #e5e7eb;
    --blue: #2563eb;
    --green: #059669;
    --amber: #d97706;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      sans-serif;
    background: var(--paper);
    color: var(--ink);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--paper);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  main {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 0 0 64px;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    width: 100%;
    background: rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .nav {
    width: min(1180px, calc(100% - 32px));
    min-height: 72px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand,
  .nav-links {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 10px;
    font-weight: 700;
    letter-spacing: 0;
  }

  .brand img {
    width: 24px;
    height: 24px;
  }

  .nav-links {
    gap: 22px;
    color: var(--muted);
    font-size: 14px;
  }

  .nav-links a:hover {
    color: var(--ink);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(420px, 1.08fr);
    gap: clamp(34px, 6vw, 76px);
    align-items: center;
    min-height: calc(100vh - 72px);
    padding: clamp(58px, 8vw, 94px) 0 42px;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--blue);
    font: 600 12px/1.4 var(--aouo-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    letter-spacing: 0;
  }

  h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(46px, 6.5vw, 82px);
    line-height: 0.94;
    font-weight: 760;
  }

  .lead {
    max-width: 620px;
    margin: 26px 0 0;
    color: var(--muted);
    font-size: clamp(18px, 1.8vw, 21px);
    line-height: 1.58;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 8px;
    font-weight: 650;
    font-size: 14px;
  }

  .button.primary {
    background: var(--ink);
    color: #fff;
  }

  .button.secondary {
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.68);
    color: var(--ink);
  }

  .diagram-shell {
    width: 100%;
    aspect-ratio: 760 / 520;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 24px 72px rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }

  .runtime-diagram {
    width: 100%;
    height: 100%;
    display: block;
  }

  .runtime-diagram rect {
    vector-effect: non-scaling-stroke;
  }

  .runtime-diagram text {
    fill: var(--ink);
    font-size: 18px;
    font-weight: 720;
  }

  .runtime-diagram .small {
    fill: var(--muted);
    font-size: 13px;
    font-weight: 500;
  }

  .incoming rect {
    fill: #eff6ff;
    stroke: #bfdbfe;
  }

  .core rect {
    fill: #ffffff;
    stroke: #d4d4d8;
  }

  .state rect {
    fill: #f0fdf4;
    stroke: #bbf7d0;
  }

  .flow-line {
    fill: none;
    stroke: #1f2937;
    stroke-width: 2;
    stroke-linecap: round;
    marker-end: url(#arrow);
    stroke-dasharray: 7 9;
    animation: dash 18s linear infinite;
    vector-effect: non-scaling-stroke;
  }

  .flow-line.direct {
    stroke-dasharray: 0;
  }

  .pulse {
    fill: var(--blue);
    opacity: 0.58;
    filter: drop-shadow(0 4px 10px rgba(37, 99, 235, 0.28));
  }

  .p2 {
    fill: var(--green);
  }

  .p3 {
    fill: var(--amber);
  }

  .start {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .link-card {
    min-height: 132px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.74);
    padding: 20px;
  }

  .link-card:hover {
    border-color: #cbd5e1;
    background: #fff;
  }

  .link-card strong {
    font-size: 18px;
  }

  .link-card span {
    color: var(--muted);
    line-height: 1.55;
  }

  .contract {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 42px;
    align-items: start;
    margin-top: 12px;
    padding: 36px 0 0;
  }

  .contract h2 {
    max-width: 520px;
    margin: 0;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.05;
  }

  .contract ol {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contract li {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 18px;
    align-items: baseline;
    border-bottom: 1px solid var(--line);
    padding: 0 0 14px;
  }

  .contract li strong {
    font: 600 13px/1.4 var(--aouo-mono);
    color: var(--blue);
    text-transform: uppercase;
  }

  .contract li span {
    color: var(--muted);
    line-height: 1.55;
  }

  @keyframes dash {
    to {
      stroke-dashoffset: -160;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-line {
      animation: none;
    }

    .pulse {
      display: none;
    }
  }

  @media (max-width: 920px) {
    .hero,
    .start,
    .contract {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding-top: 52px;
    }

    .diagram-shell {
      max-width: 760px;
    }
  }

  @media (max-width: 620px) {
    main {
      width: min(100% - 24px, 1180px);
      padding-top: 16px;
    }

    .nav {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
      padding-bottom: 14px;
    }

    .nav-links {
      gap: 16px;
    }

    .hero {
      padding-top: 42px;
    }

    .diagram-shell {
      aspect-ratio: 1 / 0.86;
    }

    .runtime-diagram text {
      font-size: 20px;
    }

    .contract li {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }
</style>
