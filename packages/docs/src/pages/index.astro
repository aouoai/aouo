---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const visionCards = [
  {
    href: '/concepts/host-model/',
    title: 'The Host Model',
    desc: 'Three intentionally separate parts: runtime, desktop, pack.',
  },
  {
    href: '/concepts/why-packs/',
    title: 'Why Packs',
    desc: 'What a pack boundary buys you that chat boxes and skill bags cannot.',
  },
  {
    href: '/concepts/example-packs/',
    title: 'Example Packs',
    desc: 'English Coach, Creator Studio, Daily Journal — three flagship shapes.',
  },
  {
    href: '/concepts/context-compiler/',
    title: 'Context Compiler',
    desc: 'How pack scope cuts routing context by 3–5× vs a flat skill bag.',
  },
  {
    href: '/concepts/builder-direction/',
    title: 'Builder Direction',
    desc: 'Where the format is going — AI-assisted app assembly.',
  },
  {
    href: '/concepts/desktop-direction/',
    title: 'Desktop Direction',
    desc: 'Local-first workspace; chat channels demoted to optional remotes.',
  },
];

const flagships = [
  {
    name: 'English Coach',
    quote: '"Remember what I got wrong last week and quiz me on it this morning."',
    sub: 'Daily missions · writing feedback · SRS · weekly progress',
  },
  {
    name: 'Creator Studio',
    quote: '"Capture this link, draft three angles, slot the best on Thursday."',
    sub: 'Sources · idea queue · drafts · brand voice · publishing calendar',
  },
  {
    name: 'Daily Journal',
    quote: '"Two weeks of notes — what kept coming up?"',
    sub: 'Daily notes · goals · mood tags · weekly reviews · action items',
  },
];

const comparisonRows = [
  {
    label: 'ChatGPT / Claude',
    sub: 'one broad conversation',
    diff: 'Each pack is its own app — own storage, memory, schedule, permissions, UI surface.',
  },
  {
    label: 'Codex / Claude Code',
    sub: 'agents for codebases',
    diff: 'AOUO is for end-user vertical agents: learning, writing, journaling, research, ops.',
  },
  {
    label: 'MCP',
    sub: 'connects models to tools',
    diff: '.aouo packages a stateful app one layer above the connectivity layer.',
  },
  {
    label: 'Skill bags',
    sub: 'flat collection of skills',
    diff: 'Packs are bounded apps with state, schedules, permissions, and evals.',
  },
];
---

<StarlightPage
  frontmatter={{
    title: 'HOME',
    description: 'Local-first agent apps, packaged as .aouo packs.',
    template: 'splash',
    hero: {
      title: 'Local-first agent apps,<br/>packaged as .aouo packs.',
      tagline:
        'A pack is more than a prompt or a folder of skills. It is an installable AI app with its own skills, durable storage, memory, schedules, tools, permissions, and UI surface.',
      actions: [
        {
          text: 'Get Started',
          link: '/getting-started/introduction/',
          icon: 'right-arrow',
          variant: 'primary',
        },
        {
          text: 'View on GitHub',
          link: 'https://github.com/aouoai/aouo',
          icon: 'external',
          variant: 'minimal',
        },
      ],
    },
  }}
>
  <div class="container-section aouo-csection" id="flow">
    <div class="container-wrapper">
      <div class="container container-padding aouo-csection-inner not-content">
        <header class="aouo-section-head">
          <p class="eyebrow">The host model</p>
          <h2>One runtime. Many isolated packs. Each pack is its own app.</h2>
        </header>
        <div class="aouo-diagram-shell" aria-label="aouo host model">
          <svg
            class="aouo-diagram"
            viewBox="0 0 880 560"
            role="img"
            aria-labelledby="flow-title flow-desc"
          >
            <title id="flow-title">aouo host model</title>
            <desc id="flow-desc">
              A user event enters through the desktop client, the runtime dispatches it to the
              active pack, and each pack remains its own isolated app with skills, memory,
              storage, schedule, permissions, and UI surface.
            </desc>
            <rect x="0" y="0" width="880" height="560" rx="10" fill="#ffffff" />

            <!-- USER entry -->
            <g class="aouo-user">
              <circle cx="440" cy="32" r="5" />
              <text x="455" y="36" class="aouo-small">user · event</text>
            </g>

            <!-- DESKTOP strip -->
            <g class="aouo-lane aouo-lane--desktop">
              <rect x="60" y="58" width="760" height="62" rx="10" />
              <text x="80" y="84" class="aouo-eyebrow">CLIENT</text>
              <text x="80" y="106" class="aouo-host-title aouo-host-title--sm">Desktop</text>
              <text x="800" y="96" text-anchor="end" class="aouo-small">install · chat · memory · db · cron · permissions</text>
            </g>

            <!-- RUNTIME band -->
            <g class="aouo-lane aouo-lane--host">
              <rect x="60" y="156" width="760" height="106" rx="12" />
              <text x="80" y="184" class="aouo-eyebrow">HOST</text>
              <text x="80" y="216" class="aouo-host-title">aouo runtime</text>
              <text x="80" y="240" class="aouo-small">
                loader · agent · scheduler · context compiler · permissions · usage
              </text>
            </g>

            <!-- 4 pack tiles, each with its own skills + cron -->
            <g class="aouo-pack" data-pack="notes">
              <rect x="60" y="320" width="170" height="220" rx="10" />
              <text x="78" y="352" class="aouo-pack-name">notes</text>
              <text x="78" y="370" class="aouo-pack-id">pack-id: notes</text>
              <line x1="74" y1="386" x2="216" y2="386" class="aouo-pack-rule" />
              <text x="78" y="408" class="aouo-pack-skill">/quick_note</text>
              <text x="78" y="430" class="aouo-pack-skill">/daily_review</text>
              <text x="78" y="452" class="aouo-pack-skill">/weekly_digest</text>
              <text x="78" y="474" class="aouo-pack-skill">/find_thread</text>
              <line x1="74" y1="494" x2="216" y2="494" class="aouo-pack-rule" />
              <text x="78" y="516" class="aouo-pack-cron">cron · 0 18 * * 0</text>
            </g>

            <g class="aouo-pack aouo-pack--active" data-pack="english-coach">
              <rect x="256" y="320" width="170" height="220" rx="10" />
              <text x="274" y="352" class="aouo-pack-name">english-coach</text>
              <text x="274" y="370" class="aouo-pack-id">pack-id: english</text>
              <line x1="270" y1="386" x2="412" y2="386" class="aouo-pack-rule" />
              <text x="274" y="408" class="aouo-pack-skill">/daily_mission</text>
              <text x="274" y="430" class="aouo-pack-skill">/writing_feedback</text>
              <text x="274" y="452" class="aouo-pack-skill">/srs_review</text>
              <text x="274" y="474" class="aouo-pack-skill">/weekly_report</text>
              <line x1="270" y1="494" x2="412" y2="494" class="aouo-pack-rule" />
              <text x="274" y="516" class="aouo-pack-cron">cron · 0 8 * * *</text>
            </g>

            <g class="aouo-pack" data-pack="create">
              <rect x="452" y="320" width="170" height="220" rx="10" />
              <text x="470" y="352" class="aouo-pack-name">create</text>
              <text x="470" y="370" class="aouo-pack-id">pack-id: create</text>
              <line x1="466" y1="386" x2="608" y2="386" class="aouo-pack-rule" />
              <text x="470" y="408" class="aouo-pack-skill">/capture_source</text>
              <text x="470" y="430" class="aouo-pack-skill">/draft_angles</text>
              <text x="470" y="452" class="aouo-pack-skill">/compose_post</text>
              <text x="470" y="474" class="aouo-pack-skill">/schedule_post</text>
              <line x1="466" y1="494" x2="608" y2="494" class="aouo-pack-rule" />
              <text x="470" y="516" class="aouo-pack-cron">cron · 0 9 * * 1-5</text>
            </g>

            <g class="aouo-pack" data-pack="journal">
              <rect x="648" y="320" width="170" height="220" rx="10" />
              <text x="666" y="352" class="aouo-pack-name">daily-journal</text>
              <text x="666" y="370" class="aouo-pack-id">pack-id: journal</text>
              <line x1="662" y1="386" x2="804" y2="386" class="aouo-pack-rule" />
              <text x="666" y="408" class="aouo-pack-skill">/daily_note</text>
              <text x="666" y="430" class="aouo-pack-skill">/mood_track</text>
              <text x="666" y="452" class="aouo-pack-skill">/weekly_review</text>
              <text x="666" y="474" class="aouo-pack-skill">/action_items</text>
              <line x1="662" y1="494" x2="804" y2="494" class="aouo-pack-rule" />
              <text x="666" y="516" class="aouo-pack-cron">cron · 0 17 * * 0</text>
            </g>

            <!-- Trunk: desktop → runtime (ambient dashed) -->
            <path class="aouo-flow-line aouo-flow-line--trunk" d="M 440 38 L 440 58" />
            <path class="aouo-flow-line aouo-flow-line--trunk" d="M 440 120 L 440 156" />

            <!-- Branches: runtime → each pack -->
            <path class="aouo-flow-line" d="M 440 262 C 440 290, 145 300, 145 320" />
            <path class="aouo-flow-line aouo-flow-line--direct" d="M 440 262 C 440 290, 341 300, 341 320" />
            <path class="aouo-flow-line" d="M 440 262 C 440 290, 537 300, 537 320" />
            <path class="aouo-flow-line" d="M 440 262 C 440 290, 733 300, 733 320" />

            <!-- Pulses: user → desktop → runtime → branch into a pack, staggered -->
            <circle class="aouo-pulse aouo-pulse--p1" r="4.5">
              <animateMotion dur="5.2s" repeatCount="indefinite"
                path="M 440 32 L 440 90 L 440 208 C 440 280, 341 295, 341 360" />
            </circle>
            <circle class="aouo-pulse aouo-pulse--p2" r="4.5">
              <animateMotion dur="6.2s" begin="1.2s" repeatCount="indefinite"
                path="M 440 32 L 440 90 L 440 208 C 440 270, 145 290, 145 360" />
            </circle>
            <circle class="aouo-pulse aouo-pulse--p3" r="4.5">
              <animateMotion dur="6.8s" begin="2.4s" repeatCount="indefinite"
                path="M 440 32 L 440 90 L 440 208 C 440 270, 733 290, 733 360" />
            </circle>
            <circle class="aouo-pulse aouo-pulse--p4" r="4.5">
              <animateMotion dur="7.4s" begin="3.6s" repeatCount="indefinite"
                path="M 440 32 L 440 90 L 440 208 C 440 280, 537 295, 537 360" />
            </circle>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <div class="container-section aouo-csection" id="shape">
    <div class="container-wrapper">
      <div class="container container-padding aouo-csection-inner not-content">
        <header class="aouo-section-head">
          <p class="eyebrow">The shape of a pack</p>
          <h2>A hard runtime boundary around six things</h2>
        </header>
        <pre
          class="aouo-code">pack = skills + storage + memory + schedule + permissions + UI surface</pre>
        <p class="aouo-prose">
          The runtime is the host. The pack is the app. The dashboard is where the two meet the
          user.
        </p>
      </div>
    </div>
  </div>

  <div class="container-section aouo-csection aouo-csection--tinted" id="vision">
    <div class="container-wrapper">
      <div class="container container-padding aouo-csection-inner not-content">
        <header class="aouo-section-head">
          <p class="eyebrow">Vision</p>
          <h2>Six concepts that define the format</h2>
        </header>
        <div class="aouo-card-grid">
          {
            visionCards.map((c) => (
              <a class="aouo-card" href={c.href}>
                <span class="aouo-card-title">
                  {c.title}
                  <span class="aouo-card-arrow">→</span>
                </span>
                <span class="aouo-card-desc">{c.desc}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="container-section aouo-csection" id="packs">
    <div class="container-wrapper">
      <div class="container container-padding aouo-csection-inner not-content">
        <header class="aouo-section-head">
          <p class="eyebrow">Pack shapes</p>
          <h2>Three flagship pack shapes the format is designed for</h2>
        </header>
        <div class="aouo-flagships">
          {
            flagships.map((p) => (
              <article>
                <h3>{p.name}</h3>
                <p class="quote">{p.quote}</p>
                <p class="sub">{p.sub}</p>
              </article>
            ))
          }
        </div>
        <p class="aouo-prose aouo-section-foot">
          A pack is judged by whether one of these keeps a real user coming back for weeks. The
          platform is downstream of the pack.
        </p>
      </div>
    </div>
  </div>

  <div class="container-section aouo-csection aouo-csection--inverted" id="not">
    <div class="container-wrapper">
      <div class="container container-padding aouo-csection-inner not-content">
        <header class="aouo-section-head">
          <p class="eyebrow">What it isn't</p>
          <h2>Not local ChatGPT. Not a framework. Not a marketplace.</h2>
        </header>
        <div class="aouo-compare">
          <div class="aouo-compare-head">
            <span>Compared with</span>
            <span>AOUO is different because</span>
          </div>
          {
            comparisonRows.map((r) => (
              <div class="aouo-compare-row">
                <div class="aouo-compare-left">
                  <span class="aouo-compare-name">{r.label}</span>
                  <span class="aouo-compare-sub">{r.sub}</span>
                </div>
                <div class="aouo-compare-diff">{r.diff}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="container-section aouo-csection aouo-csection--end" id="start">
    <div class="container-wrapper">
      <div class="container container-padding aouo-csection-inner not-content">
        <header class="aouo-section-head">
          <p class="eyebrow">Quick start</p>
          <h2>Try the runtime. Build a pack.</h2>
        </header>
        <div class="aouo-cta">
          <div class="aouo-cta-text">
            <p class="aouo-prose">
              Pre-alpha. The pack ABI is moving. The runtime, scheduler, sample packs, and
              dashboard are in. Shape is still being narrowed — which is exactly when feedback
              matters.
            </p>
            <div class="aouo-cta-actions">
              <a class="aouo-cta-btn aouo-cta-btn--primary" href="/getting-started/introduction/">
                Get started <span aria-hidden="true">→</span>
              </a>
              <a class="aouo-cta-btn" href="https://github.com/aouoai/aouo">
                View on GitHub <span aria-hidden="true">↗</span>
              </a>
            </div>
          </div>
          <pre class="aouo-terminal"><span class="aouo-terminal-head">try it locally</span><span class="aouo-terminal-line"><span class="aouo-terminal-prompt">$</span> git clone https://github.com/aouoai/aouo</span><span class="aouo-terminal-line"><span class="aouo-terminal-prompt">$</span> cd aouo &amp;&amp; pnpm install</span><span class="aouo-terminal-line"><span class="aouo-terminal-prompt">$</span> pnpm --filter @aouo/agent dev</span><span class="aouo-terminal-comment"># pre-alpha · no install artifact yet</span></pre>
        </div>
      </div>
    </div>
  </div>
</StarlightPage>

<style>
  /* ---------- Section chrome (one container-section per block) ---------- */
  .aouo-csection-inner {
    padding-block: 5.5rem !important;
  }

  /* Tinted / inverted bg stays inside the content column;
     only the .container-section bottom border bleeds out to the viewport edges. */
  .aouo-csection--tinted .aouo-csection-inner {
    background: color-mix(in oklab, var(--muted) 60%, transparent);
  }

  .aouo-csection--inverted .aouo-csection-inner {
    background: #0f0f10;
    color: #e6e6e8;
  }

  .aouo-csection--inverted .aouo-section-head .eyebrow {
    color: #a3a3a8;
  }

  .aouo-csection--inverted .aouo-section-head h2 {
    color: #f4f4f5;
  }

  /* Kill the bottom border on the last block so the site footer's
     top border is the only divider — no doubled line. */
  .aouo-csection--end {
    border-bottom: 0 !important;
  }

  /* ---------- Host model diagram ---------- */
  .aouo-diagram-shell {
    width: 100%;
    max-width: 960px;
    margin: 2.25rem auto 0;
    aspect-ratio: 880 / 560;
    border: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
    border-radius: 12px;
    background: #ffffff;
    box-shadow: 0 24px 72px rgba(15, 23, 42, 0.06);
    overflow: hidden;
  }

  :global([data-theme='dark']) .aouo-diagram-shell {
    border-color: var(--border);
    box-shadow: 0 24px 72px rgba(0, 0, 0, 0.35);
  }

  .aouo-diagram {
    width: 100%;
    height: 100%;
    display: block;
  }

  .aouo-diagram rect {
    vector-effect: non-scaling-stroke;
  }

  .aouo-diagram text {
    fill: #171717;
    font-family: var(--aouo-mono, ui-monospace, monospace);
  }

  .aouo-diagram .aouo-eyebrow {
    fill: #6b7280;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
  }

  .aouo-diagram .aouo-host-title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .aouo-diagram .aouo-host-title--sm {
    font-size: 16px;
  }

  .aouo-diagram .aouo-small {
    fill: #5f5f66;
    font-size: 13px;
    font-weight: 500;
  }

  .aouo-user circle {
    fill: #1f2937;
  }

  .aouo-lane--desktop rect {
    fill: #fafafa;
    stroke: #d4d4d8;
    stroke-width: 1;
  }

  .aouo-lane--host rect {
    fill: #ffffff;
    stroke: #1f2937;
    stroke-width: 1.5;
  }

  .aouo-pack rect {
    fill: #f9fafb;
    stroke: #d4d4d8;
    stroke-width: 1;
  }

  .aouo-pack .aouo-pack-name {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.005em;
  }

  .aouo-pack .aouo-pack-id {
    fill: #71717a;
    font-size: 10px;
    letter-spacing: 0.02em;
  }

  .aouo-pack .aouo-pack-rule {
    stroke: #e4e4e7;
    stroke-width: 1;
  }

  .aouo-pack .aouo-pack-skill {
    fill: #3f3f46;
    font-size: 12.5px;
  }

  .aouo-pack .aouo-pack-cron {
    fill: #71717a;
    font-size: 11px;
    letter-spacing: 0.02em;
  }

  .aouo-pack--active rect:first-of-type {
    fill: #eff6ff;
    stroke: #2563eb;
    stroke-width: 1.5;
  }

  .aouo-pack--active .aouo-pack-rule {
    stroke: #bfdbfe;
  }

  .aouo-pack--active .aouo-pack-skill {
    fill: #1e3a8a;
  }

  .aouo-pack--active .aouo-pack-cron {
    fill: #2563eb;
  }

  .aouo-flow-line {
    fill: none;
    stroke: #1f2937;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-dasharray: 6 8;
    animation: aouo-dash 18s linear infinite;
    vector-effect: non-scaling-stroke;
  }

  .aouo-flow-line--direct {
    stroke-dasharray: 0;
    stroke-width: 2;
    stroke: #2563eb;
  }

  .aouo-flow-line--trunk {
    stroke: #9ca3af;
    stroke-width: 1.25;
    stroke-dasharray: 4 6;
  }

  .aouo-pulse {
    fill: #2563eb;
    opacity: 0.7;
    filter: drop-shadow(0 4px 10px rgba(37, 99, 235, 0.28));
  }

  .aouo-pulse--p2 {
    fill: #059669;
    filter: drop-shadow(0 4px 10px rgba(5, 150, 105, 0.28));
  }

  .aouo-pulse--p3 {
    fill: #d97706;
    filter: drop-shadow(0 4px 10px rgba(217, 119, 6, 0.28));
  }

  .aouo-pulse--p4 {
    fill: #7c3aed;
    filter: drop-shadow(0 4px 10px rgba(124, 58, 237, 0.28));
  }

  @keyframes aouo-dash {
    to {
      stroke-dashoffset: -160;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .aouo-flow-line {
      animation: none;
    }
    .aouo-pulse {
      display: none;
    }
  }

  .aouo-section-head {
    margin-bottom: 2.25rem;
  }

  .aouo-section-head .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--muted-foreground);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  .aouo-section-head .eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.7;
    display: inline-block;
  }

  .aouo-section-head h2 {
    margin: 0;
    font-size: 1.75rem;
    line-height: 1.35;
    letter-spacing: -0.015em;
    font-weight: 700;
    color: var(--foreground);
    max-width: 36ch;
    text-wrap: balance;
  }

  .aouo-code {
    margin: 0 0 1.25rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--aouo-doc-code-border, var(--border));
    border-radius: 10px;
    background: var(--aouo-doc-code-bg, var(--muted));
    font-family: var(--aouo-mono);
    font-size: 0.875rem;
    overflow-x: auto;
    white-space: pre;
    color: var(--foreground);
  }

  .aouo-prose {
    margin: 0;
    color: var(--muted-foreground);
    max-width: 60ch;
    line-height: 1.75;
    font-size: 1rem;
  }

  .aouo-section-foot {
    margin-top: 2.25rem;
  }

  .aouo-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .aouo-card {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.5rem 1.5rem;
    border: 1px solid color-mix(in oklab, var(--border) 40%, transparent);
    border-radius: 10px;
    color: inherit;
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      background 0.15s ease,
      transform 0.15s ease;
  }

