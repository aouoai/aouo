<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.svg" />
    <title>404 - aouo</title>
  </head>
  <body>
    <main>
      <a class="brand" href="/" aria-label="aouo home">
        <img src="/favicon.svg" alt="" />
        <span>AOUO</span>
      </a>
      <section>
        <p class="code">404</p>
        <h1>Page not found.</h1>
        <p class="lead">The route does not exist. Start from the homepage or open the runtime docs.</p>
        <div class="actions">
          <a class="button primary" href="/">Home</a>
          <a class="button secondary" href="/getting-started/quickstart/">Quick Start</a>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --ink: #171717;
    --muted: #66666d;
    --line: #e5e7eb;
    --paper: #ffffff;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      sans-serif;
    background: var(--paper);
    color: var(--ink);
  }

  * {
    box-sizing: border-box;
  }

  body {
    min-height: 100vh;
    margin: 0;
    background: var(--paper);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  main {
    width: min(900px, calc(100% - 32px));
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr;
    margin: 0 auto;
    padding: 24px 0 72px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    height: 48px;
    font-weight: 700;
  }

  .brand img {
    width: 24px;
    height: 24px;
  }

  section {
    align-self: center;
    max-width: 620px;
    padding: 64px 0;
  }

  .code {
    margin: 0 0 14px;
    color: #2563eb;
    font: 600 13px/1.4 ui-monospace, 'SFMono-Regular', 'SF Mono', Consolas, monospace;
    letter-spacing: 0.1em;
  }

  h1 {
    margin: 0;
    font-size: clamp(48px, 9vw, 88px);
    line-height: 0.94;
    letter-spacing: 0;
  }

  .lead {
    max-width: 520px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 20px;
    line-height: 1.55;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 8px;
    font-weight: 650;
    font-size: 14px;
  }

  .button.primary {
    background: var(--ink);
    color: #fff;
  }

  .button.secondary {
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.72);
  }
</style>
